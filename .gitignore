# Ignore all image files in image directories
*/image/
**/image/

# Ignore common image file types
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp
*.svg

# Ignore Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Ignore virtual environment
.venv/
venv/
env/

# Ignore environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore log files
*.log
logs/

# Ignore temporary files
*.tmp
*.temp
~*